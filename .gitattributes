# Files generated by tools/extract-town.mjs are byte-compared for idempotence —
# pin them to LF so CI (Linux) and local (Windows) runs agree and commits stay
# noise-free.
src/data/postmark/*.json text eol=lf
public/atelier/postmark/data/** text eol=lf
public/atelier/postmark/atlas/town.html text eol=lf
public/atelier/postmark/daily/the-office.html text eol=lf
