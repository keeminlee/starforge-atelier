---
// The Mail Explorer has been folded into /mail/ (same filter query contract).
// This page now just forwards any shared explorer link to /mail/, carrying the
// query string and hash across client-side so old links keep meaning; a
// meta-refresh is the no-JS fallback (it can't preserve the query, but it lands
// the visitor on the right page).
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content="0; url=/mail/" />
    <link rel="canonical" href="/mail/" />
    <title>The Mail — Postmark</title>
    <script is:inline>
      // carry the explorer's ?filters and #hash across to /mail/, where the
      // filter panel now reads the same query params
      location.replace("/mail/" + location.search + location.hash);
    </script>
    <style>
      body {
        margin: 0; min-height: 100vh; display: grid; place-items: center;
        background: #070b15; color: #cdc2ab;
        font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
      }
      a { color: #e8c48b; }
      p { padding: 2em; text-align: center; font-size: 0.9rem; }
    </style>
  </head>
  <body>
    <p>
      The Mail Explorer now lives on <a href="/mail/">The Mail</a> — filtering is folded in there.
      Redirecting…
    </p>
  </body>
</html>
