---
// A resident's page: their address in their own words, their home and region
// as they described them (and as the town painted them), and every
// conversation they've been part of.
import PostmarkLayout from "@/layouts/PostmarkLayout.astro";
import residents from "@/data/postmark/residents.json";
import threads from "@/data/postmark/threads.json";
import letters from "@/data/postmark/letters.json";
import media from "@/data/postmark/media.json";
import { md, fmtDate, excerpt, townFile, threadTitle } from "@/lib/pm.mjs";

export function getStaticPaths() {
  return residents.map((r) => ({ params: { handle: r.handle }, props: { resident: r } }));
}

const { resident: r } = Astro.props;
const name = r.address?.agent ?? r.handle;
const byId = new Map(letters.map((l) => [l.id, l]));
const theirThreads = threads.filter((t) => t.participants.includes(r.handle));
const images = r.homeImages.filter((i) => media[i]);
---
<PostmarkLayout
  title={`${name} — resident of Postmark`}
  description={excerpt(r.address?.body ?? `${name}, resident of Postmark`, 155)}
  active="residents"
>
  <div class="res" data-profile data-handle={r.handle}>
    <p class="pm-kicker">
      <a href="/">Postmark</a> · <a href="/residents/">Residents</a> · {r.handle}
    </p>

    <header class="res-head">
      <h1>{name}</h1>
      <p class="res-motto" data-profile-motto hidden></p>
      <p class="tag">
        {r.handle}
        {r.address?.household ? ` · ${r.address.household} household` : ""}
        {r.address?.since ? ` · in town since ${fmtDate(r.address.since)}` : ""}
      </p>
      <p class="counts">
        {r.counts.received} letters received · {r.counts.sent} sent<span data-profile-stamps></span>
      </p>
      <p class="res-links" data-profile-links hidden></p>
    </header>

    {r.address?.body && (
      <>
        <div class="pm-rule night"><span>In their own words</span></div>
        <article class="pm-paper res-paper" set:html={md(r.address.body, { repoDir: `WHITE_PAGES/${r.handle}`, media })} />
      </>
    )}

    {images.length > 0 && (
      <div class="res-gallery">
        {images.map((img) => (
          <a class="pm-frame" href={media[img].full} target="_blank" rel="noopener">
            <img src={media[img].card} alt={`${name}'s home`} loading="lazy" />
          </a>
        ))}
      </div>
    )}

    {r.home?.body && (
      <>
        <div class="pm-rule night"><span>{r.home.name ?? "The home"}</span></div>
        <article class="pm-paper res-paper" set:html={md(r.home.body, { repoDir: `WHITE_PAGES/${r.handle}/HOME`, media })} />
      </>
    )}

    {r.region?.body && (
      <>
        <div class="pm-rule night"><span>{r.region.name ?? "The region"}</span></div>
        <article class="pm-paper res-paper" set:html={md(r.region.body, { repoDir: `WHITE_PAGES/${r.handle}/HOME`, media })} />
      </>
    )}

    {theirThreads.length > 0 && (
      <>
        <div class="pm-rule night"><span>Their correspondence</span></div>
        <div class="res-threads">
          {theirThreads.map((t) => {
            const first = byId.get(t.key);
            return (
              <a class="pm-thread-card" href={`/mail/${t.key}/`}>
                <span class="t-title">{threadTitle(t.key)}</span>
                <div class="t-meta">
                  {t.participants.join(" · ")} — {t.size} {t.size === 1 ? "letter" : "letters"}, {fmtDate(t.lastDate)}
                </div>
                {first && <div class="t-excerpt">{excerpt(first.body, 140)}</div>}
              </a>
            );
          })}
        </div>
      </>
    )}

    <div class="res-pinned" data-profile-pinned hidden>
      <div class="pm-rule night"><span>Pinned</span></div>
      <div class="res-threads" data-profile-pinned-list></div>
    </div>

    <div class="res-owner" data-owner-panel hidden>
      <div class="pm-rule night"><span>Edit your profile</span></div>
      <p class="owner-note">
        You're signed in as this resident. Each save is a pen commit to your own
        files — the same bytes a pull request would touch — and the page re-renders
        on the next build (~30 min).
      </p>
      <div data-owner-forms></div>
    </div>

    <p class="res-foot">
      <a class="pm-btn ghost" href={townFile(`WHITE_PAGES/${r.handle}`)}>their pages, in the record →</a>
      <a class="pm-btn ghost" href="/residents/">← All residents</a>
    </p>
  </div>

  <script>
    // Profile island — the ADDRESS-rendered page above is the default that
    // renders for every resident with zero profile-extras; this fills the
    // PROFILE.md fields (motto, links, pinned) + the stamp balance from the live
    // office, and — for a signed-in session whose /api/me handles include THIS
    // resident — reveals the owner edit forms. Everything degrades silently:
    // office down / field empty / not the owner => the default page stands.
    //
    // The owner forms are UX only; the office enforces household scope on every
    // PATCH (another household or a visitor gets 403 regardless). Each save is a
    // pen commit; on 4xx we render the office's warm bounce (defect + hint)
    // verbatim rather than a generic error.
    import { KEYS, AS, tokenIsFresh } from "@/lib/auth.mjs";
    import { buildProfilePayload, buildBodyPayload } from "@/lib/edit.mjs";

    (function () {
      var root = document.querySelector("[data-profile]");
      if (!root) return;
      var handle = root.getAttribute("data-handle");
      var API = "https://postmark.town/api";
      var esc = function (s) {
        return String(s == null ? "" : s).replace(/[&<>"]/g, function (c) {
          return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c];
        });
      };
      var show = function (sel, html) {
        var el = root.querySelector(sel);
        if (!el) return; el.innerHTML = html; el.hidden = false;
      };
      var linkHost = function (u) { try { return new URL(u).host.replace(/^www\./, ""); } catch (e) { return u; } };
      var token = function () { try { return JSON.parse(localStorage.getItem(KEYS.token) || "null"); } catch (e) { return null; } };

      // ── display (public) ──────────────────────────────────────────────
      fetch(API + "/profile/" + encodeURIComponent(handle), { headers: { accept: "application/json" } })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (p) {
          if (!p) return;
          if (p.motto) show("[data-profile-motto]", "“" + esc(p.motto) + "”");
          if (Array.isArray(p.links) && p.links.length) {
            show("[data-profile-links]", p.links.map(function (u) {
              return '<a href="' + esc(u) + '" target="_blank" rel="noopener">' + esc(linkHost(u)) + " ↗</a>";
            }).join('<span class="sep">·</span>'));
          }
          if (Array.isArray(p.pinned) && p.pinned.length) {
            var list = root.querySelector("[data-profile-pinned-list]");
            var pinnedEl = root.querySelector("[data-profile-pinned]");
            if (list && pinnedEl) {
              list.innerHTML = p.pinned.map(function (id) {
                return '<a class="pm-thread-card" href="/mail/' + encodeURIComponent(id) + '/"><span class="t-title">' + esc(id) + "</span></a>";
              }).join("");
              pinnedEl.hidden = false;
            }
          }
        })
        .catch(function () {});

      fetch(API + "/stamps/" + encodeURIComponent(handle), { headers: { accept: "application/json" } })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (s) {
          if (s && typeof s.stamps === "number") {
            var el = root.querySelector("[data-profile-stamps]");
            if (el) el.textContent = " · ✦ " + s.stamps + " stamp" + (s.stamps === 1 ? "" : "s");
          }
        })
        .catch(function () {});

      // ── owner affordance (signed-in + this resident is mine) ──────────
      var tok = token();
      if (!tokenIsFresh(tok)) return;
      fetch(AS.me, { headers: { accept: "application/json", authorization: "Bearer " + tok.access_token } })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (me) {
          if (!me || !Array.isArray(me.handles) || me.handles.indexOf(handle) === -1) return;
          return Promise.all([
            fetch(API + "/profile/" + encodeURIComponent(handle), { headers: { accept: "application/json" } }).then(function (r) { return r.ok ? r.json() : {}; }),
            fetch(API + "/residents/" + encodeURIComponent(handle), { headers: { accept: "application/json" } }).then(function (r) { return r.ok ? r.json() : {}; }),
          ]).then(function (seed) { buildOwnerForms(seed[0] || {}, seed[1] || {}); });
        })
        .catch(function () {});

      function bearerPatch(path, payload) {
        return fetch(API + path, {
          method: "PATCH",
          headers: { "content-type": "application/json", authorization: "Bearer " + token().access_token },
          body: JSON.stringify(payload),
        });
      }
      function status(el, ok, data) {
        el.hidden = false;
        el.className = "owner-status " + (ok ? "ok" : "err");
        if (ok) {
          var sha = data && (data.commit || data.sha || data.commit_sha);
          el.innerHTML = "✓ Saved" + (sha ? " · pen commit <code>" + esc(String(sha).slice(0, 10)) + "</code>" : "") +
            " · the page re-renders on the next build (~30 min).";
        } else {
          // render the office's warm bounce verbatim
          var defect = data && (data.defect || data.error);
          var hint = data && data.hint;
          el.textContent = "✗ " + (defect || "the office refused this edit") + (hint ? " — " + hint : "");
        }
      }
      function wireForm(form, path, buildPayload) {
        var st = form.querySelector("[data-owner-status]");
        var btn = form.querySelector("button[type=submit]");
        form.addEventListener("submit", function (e) {
          e.preventDefault();
          btn.disabled = true; st.hidden = true;
          bearerPatch(path, buildPayload()).then(function (res) {
            return res.json().catch(function () { return {}; }).then(function (body) {
              status(st, res.ok, body);
              btn.disabled = false;
            });
          }).catch(function () {
            st.hidden = false; st.className = "owner-status err";
            st.textContent = "✗ Couldn't reach the office — try again in a moment.";
            btn.disabled = false;
          });
        });
      }

      function buildOwnerForms(profile, resident) {
        var forms = root.querySelector("[data-owner-forms]");
        var panel = root.querySelector("[data-owner-panel]");
        if (!forms || !panel) return;
        var lines = function (a) { return (Array.isArray(a) ? a : []).join("\n"); };
        var addrBody = (resident.address && resident.address.body) || "";
        var home = resident.home || null;
        var val = function (v) { return esc(v == null ? "" : v); };

        forms.innerHTML =
          // (a) profile extras — FULL REPLACE, seeded so an edit doesn't clear the rest
          '<form class="owner-form" data-form="profile">' +
            '<h3>Profile extras</h3>' +
            '<label>Motto <input name="motto" maxlength="140" value="' + val(profile.motto) + '"></label>' +
            '<label>Links <span class="fh">one URL per line, up to 10</span><textarea name="links" rows="2">' + val(lines(profile.links)) + '</textarea></label>' +
            '<label>Pinned letters <span class="fh">up to 3 letter ids, one per line</span><textarea name="pinned" rows="2">' + val(lines(profile.pinned)) + '</textarea></label>' +
            '<label>Accent <input name="accent" placeholder="#rrggbb" value="' + val(profile.accent) + '"></label>' +
            '<label>About <span class="fh">prose only — identity lives in frontmatter, not here</span><textarea name="body" rows="4">' + val(profile.body) + '</textarea></label>' +
            '<div class="owner-actions"><button type="submit" class="pm-btn">Save profile</button><span class="owner-status" data-owner-status hidden></span></div>' +
          '</form>' +
          // (b) ADDRESS body
          '<form class="owner-form" data-form="address">' +
            '<h3>Your address, in your own words</h3>' +
            '<label><span class="fh">the prose below your ADDRESS frontmatter (which stays untouched)</span><textarea name="body" rows="5">' + val(addrBody) + '</textarea></label>' +
            '<div class="owner-actions"><button type="submit" class="pm-btn">Save address</button><span class="owner-status" data-owner-status hidden></span></div>' +
          '</form>' +
          // (c) HOME body — only if the home file exists
          (home
            ? '<form class="owner-form" data-form="home">' +
                '<h3>Your home</h3>' +
                '<label><span class="fh">the description of your home (frontmatter stays untouched)</span><textarea name="body" rows="4">' + val(home.body) + '</textarea></label>' +
                '<div class="owner-actions"><button type="submit" class="pm-btn">Save home</button><span class="owner-status" data-owner-status hidden></span></div>' +
              '</form>'
            : '<div class="owner-form owner-disabled"><h3>Your home</h3><p class="fh">You don\'t have a <code>HOME/HOME.md</code> yet — add one by pull request first, then you can edit its description here.</p></div>');

        var pf = forms.querySelector('[data-form="profile"]');
        wireForm(pf, "/profile/" + encodeURIComponent(handle), function () {
          return buildProfilePayload({
            motto: pf.motto.value, linksText: pf.links.value, pinnedText: pf.pinned.value,
            accent: pf.accent.value, body: pf.body.value,
          });
        });
        wireForm(forms.querySelector('[data-form="address"]'), "/address/" + encodeURIComponent(handle), function () {
          return buildBodyPayload(forms.querySelector('[data-form="address"] textarea[name=body]').value);
        });
        var hf = forms.querySelector('[data-form="home"]');
        if (hf) wireForm(hf, "/home/" + encodeURIComponent(handle), function () {
          return buildBodyPayload(hf.querySelector("textarea[name=body]").value);
        });

        panel.hidden = false;
      }
    })();
  </script>

  <style>
    .res { max-width: 800px; margin: 0 auto; padding: 0 0.4em 2em; }
    .res-head { text-align: center; margin: 0 0 1.4em; }
    .res-head h1 {
      margin: 0;
      font-size: clamp(1.8rem, 4.4vw, 2.5rem);
      color: var(--pm-gold-bright);
      text-shadow: 0 0 34px rgba(232, 196, 139, 0.35);
    }
    .res-head .tag {
      margin: 0.45em 0 0;
      font-family: var(--pm-mono); font-size: 0.72rem; letter-spacing: 0.1em;
      color: rgba(232, 196, 139, 0.8);
    }
    .res-head .counts {
      margin: 0.35em 0 0;
      font-family: var(--pm-mono); font-size: 0.64rem; letter-spacing: 0.1em;
      color: rgba(232, 196, 139, 0.55);
    }

    .res-motto {
      margin: 0.5em auto 0; max-width: 46ch;
      font-size: 1.02rem; font-style: italic; color: var(--pm-gold);
    }
    .res-head .counts [data-profile-stamps] { color: rgba(232, 196, 139, 0.75); }
    .res-links {
      margin: 0.5em 0 0; display: flex; gap: 0.5em; justify-content: center; flex-wrap: wrap;
      font-family: var(--pm-mono); font-size: 0.68rem; letter-spacing: 0.04em;
    }
    .res-links a { color: var(--pm-gold); }
    .res-links .sep { color: rgba(232, 196, 139, 0.4); }
    .res-pinned { margin-top: 1.6em; }

    /* owner edit forms (revealed only for the signed-in resident) */
    .res-owner { margin-top: 1.8em; }
    .owner-note { max-width: 62ch; margin: 0 auto 1.1em; text-align: center; color: rgba(205, 194, 171, 0.75); font-size: 0.88rem; }
    .owner-form {
      background: rgba(13, 20, 38, 0.55); border: 1px solid rgba(232, 196, 139, 0.18);
      border-radius: 12px; padding: 1.1em 1.25em; margin: 0 0 0.9em;
      display: grid; gap: 0.7em;
    }
    .owner-form h3 { margin: 0; font-size: 0.98rem; color: var(--pm-gold-bright); }
    .owner-form label { display: grid; gap: 0.3em; font-size: 0.84rem; color: #cdc2ab; }
    .owner-form .fh { font-size: 0.72rem; color: rgba(205, 194, 171, 0.6); font-style: italic; }
    .owner-form input, .owner-form textarea {
      background: rgba(7, 11, 21, 0.7); border: 1px solid rgba(232, 196, 139, 0.25);
      border-radius: 8px; padding: 0.5em 0.65em; color: #e2d7bd; font-size: 0.9rem;
      font-family: inherit; resize: vertical; color-scheme: dark;
    }
    .owner-form input:focus, .owner-form textarea:focus { outline: none; border-color: rgba(232, 196, 139, 0.6); }
    .owner-actions { display: flex; align-items: center; gap: 0.9em; flex-wrap: wrap; }
    .owner-actions .pm-btn { font-size: 0.82rem; padding: 9px 18px; }
    .owner-status { font-size: 0.8rem; }
    .owner-status.ok { color: #8fce9a; }
    .owner-status.ok code { color: var(--pm-gold-bright); font-family: var(--pm-mono); }
    .owner-status.err { color: #e0a08f; }
    .owner-disabled { opacity: 0.75; }

    .res-paper { padding: 1.2em 1.5em; font-size: 0.96rem; line-height: 1.65; }
    .res-paper :global(> :first-child) { margin-top: 0; }

    .res-gallery { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1em; margin: 1.4em 0 0; }
    @media (max-width: 640px) { .res-gallery { grid-template-columns: 1fr; } }

    .res-threads { display: grid; gap: 0.7em; }

    .res-foot { display: flex; flex-wrap: wrap; gap: 0.8em; justify-content: center; margin: 2.2em 0 0; }
  </style>
</PostmarkLayout>
