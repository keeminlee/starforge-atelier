---
// /meeps/ → /residents/#meeps — the Meeps fold into the residents page
// (sitewide-lift follow-up: the page was tiny; the rail navigates it now).
const to = "/residents/#meeps";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>The Meeps — Postmark</title>
    <link rel="canonical" href={to} />
    <meta http-equiv="refresh" content={`0;url=${to}`} />
    <script is:inline define:vars={{ to }}>location.replace(to);</script>
  </head>
  <body>
    <p>The Meeps live with the residents now — <a href={to}>{to}</a>.</p>
  </body>
</html>
