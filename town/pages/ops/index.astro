---
// The ops hub — the operator's landing, the small shelf of dashboards Keemin
// and the operators reach for. Astro-hosted (gold plan postmark-ops-hub) so it
// stops being a box-only static file that drifts out of the repo's sight.
//
// This page is a directory, not a tool: three baseball cards, each a door to a
// dashboard. The Principal's Desk is astro-hosted alongside this page; Traffic
// and Git are box-generated dashboards that keep living on the box — the cards
// just point at them (relative links under /ops/).
//
// Internal surface: noindex is emitted in the layout head via PostmarkLayout's
// `noindex` prop (an operator hub is not a public page).
import PostmarkLayout from "@/layouts/PostmarkLayout.astro";

// The three dashboards. Relative hrefs under /ops/ — this page is served at
// /ops/ (index.html), so `desk/` → /ops/desk/, etc.
const cards = [
  {
    href: "desk/",
    emblem: "✒", // ✒ a nib — the town's own pen
    kind: "Console",
    title: "The Principal's Desk",
    line: "Gift stamps to a resident, minted with the town's own pen.",
  },
  {
    href: "traffic/",
    emblem: "⇅", // ⇅ flow both ways
    kind: "Dashboard",
    title: "Traffic",
    line: "Box + API traffic, GitHub views and clones.",
  },
  {
    href: "git/",
    emblem: "⎇", // ⎇ the branch glyph
    kind: "Dashboard",
    title: "Git activity",
    line: "PR funnel, merges by actor, commits, envelope-defect trend, queue health.",
  },
];
---
<PostmarkLayout
  title="Postmark ops — operator dashboards"
  description="The operator hub: the small shelf of dashboards for keeping the town."
  active=""
  noindex={true}
>
  <div class="opshub">
    <p class="pm-kicker"><a href="/">Postmark</a> · Ops</p>

    <header class="ops-head">
      <h1>Postmark ops</h1>
      <p class="tag">operator dashboards · the shelf for keeping the town</p>
    </header>

    <nav class="ops-cards" aria-label="Operator dashboards">
      {cards.map((c) => (
        <a class="opscard" href={c.href}>
          <span class="opscard-emblem" aria-hidden="true">{c.emblem}</span>
          <span class="opscard-txt">
            <span class="opscard-kind">{c.kind}</span>
            <span class="opscard-title">{c.title}</span>
            <span class="opscard-line">{c.line}</span>
          </span>
        </a>
      ))}
    </nav>
  </div>

  <style>
    /* the ops hub. All static Astro HTML, so scoped styles are the right call
       (unlike the desk, whose JS-injected rows forced is:global). The --pm-*
       tokens, .pm-kicker, and the .pm shell all come from the global
       postmark.css and reach this scoped markup the same as any town page. */
    .opshub { max-width: 820px; margin: 0 auto; padding: 0 0.4em 2.4em; }

    .opshub .ops-head { text-align: center; margin: 0 0 1.9em; }
    .opshub .ops-head h1 {
      margin: 0; font-size: clamp(1.9rem, 4.6vw, 2.6rem);
      color: var(--pm-gold-bright); text-shadow: 0 0 34px rgba(232, 196, 139, 0.35);
    }
    .opshub .ops-head .tag {
      margin: 0.4em 0 0; font-family: var(--pm-mono); font-size: 0.72rem;
      letter-spacing: 0.12em; color: rgba(232, 196, 139, 0.8);
    }

    /* ── the baseball cards, ported from residents/[handle].astro ─────────
       The static resting card + the calm gold-glow hover lift. The circle-morph
       machinery there is for its open-a-read interaction; a directory of links
       has no open state, so only the resting look is carried over. */
    .opshub .ops-cards {
      display: flex; flex-wrap: wrap; gap: 1em;
      align-items: stretch; margin: 0;
    }
    .opshub .opscard {
      flex: 1 1 220px; min-width: 0;
      display: flex; flex-direction: column; text-align: left;
      background: rgba(13, 20, 38, 0.72);
      border: 1px solid rgba(232, 196, 139, 0.2); border-radius: 12px;
      overflow: hidden; text-decoration: none; color: inherit;
      transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    }
    /* the Residents-directory hover mechanic — a gold glow + 2px lift, the calm
       affordance that says "open me" */
    .opshub .opscard:hover {
      border-color: rgba(232, 196, 139, 0.55); transform: translateY(-2px);
      box-shadow: 0 6px 22px rgba(0, 0, 0, 0.35), 0 0 18px rgba(232, 196, 139, 0.12);
    }
    .opshub .opscard:focus-visible {
      outline: 2px solid var(--pm-gold-bright); outline-offset: 3px;
      border-color: rgba(232, 196, 139, 0.7);
    }

    .opshub .opscard-emblem {
      display: grid; place-items: center; height: 118px;
      background: rgba(28, 44, 79, 0.5); color: rgba(232, 196, 139, 0.55);
      font-size: 2.4rem; line-height: 1; letter-spacing: 0;
    }
    .opshub .opscard-txt {
      display: flex; flex-direction: column; gap: 0.35em;
      padding: 0.95em 1.1em 1.15em;
    }
    .opshub .opscard-kind {
      font-family: var(--pm-mono); font-size: 0.72rem; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--pm-gold);
    }
    .opshub .opscard-title {
      font-size: 1.12rem; font-weight: 700; color: var(--pm-gold-bright); line-height: 1.25;
    }
    .opshub .opscard-line { font-size: 0.9rem; color: #cdc2ab; line-height: 1.5; }
  </style>
</PostmarkLayout>
