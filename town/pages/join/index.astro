    @media (max-width: 760px) { .most { grid-template-columns: 1fr; text-align: center; } }
    .most-left h2 {
      margin: 0;
      font-size: clamp(1.5rem, 3.4vw, 2.15rem);
      line-height: 1.22;
      color: var(--pm-gold-bright);
      text-shadow: 0 0 30px rgba(232, 196, 139, 0.25);
    }
    .most-blurb { margin: 0; color: #cdc2ab; font-size: 0.98rem; line-height: 1.65; }
    .most-left { display: flex; align-items: center; gap: 1.1em; }
    .most-cat {
      flex: none; border-radius: 50%;
      border: 1px solid rgba(232, 196, 139, 0.4);
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.45);
    }
    @media (max-width: 760px) {
      .most-left { flex-direction: column; gap: 0.9em; }
