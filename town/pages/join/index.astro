      background: rgba(13, 20, 38, 0.72);
      border: 1px solid rgba(232, 196, 139, 0.22);
      border-radius: 12px;
    }
    .fold summary:hover { border-color: rgba(232, 196, 139, 0.55); }
    .fold[open] summary { border-radius: 12px 12px 0 0; }
    .fold-body { padding: 1.1em 1.4em; font-size: 0.92rem; line-height: 1.6; border-radius: 0 0 12px 12px; }
    .fold-body :global(> :first-child) { margin-top: 0; }

    .join-foot {
      margin: 1.6em 0 0; text-align: center;
      color: rgba(205, 194, 171, 0.7); font-size: 0.88rem;
    }
    .join-foot a { color: var(--pm-gold); }
  </style>

  <script>
    import { KEYS, OFFICE, tokenIsFresh } from "@/lib/auth.mjs";

    // the key desk: POST /keys with the site's office session; the key is shown once.
    // Until the office endpoint ships, a 404/405 answers with the Discord fallback.
    (function () {
      var btn = document.querySelector("[data-keygen-btn]");
      var status = document.querySelector("[data-keygen-status]");
      var out = document.querySelector("[data-keygen-out]");
      var keyEl = document.querySelector("[data-keygen-key]");
      var copy = document.querySelector("[data-keygen-copy]");
      if (!btn) return;
      var BASE = (function () { try { return localStorage.getItem("pm.office.base") || OFFICE; } catch { return OFFICE; } })();
      function say(msg) {
        if (!msg) { status.hidden = true; status.textContent = ""; return; }
        status.hidden = false; status.textContent = msg;
      }
      var busy = false;
      btn.addEventListener("click", async function () {
        if (busy) return;
        var tok = null;
        try { tok = JSON.parse(localStorage.getItem(KEYS.token) || "null"); } catch {}
        if (!tokenIsFresh(tok)) { say("sign in first — the Sign in button, top right — then come back to this page."); return; }
        busy = true; say("asking the office…");
        try {
          var res = await fetch(BASE + "/keys", {
            method: "POST",
            headers: { accept: "application/json", authorization: "Bearer " + tok.access_token },
          });
          if (res.ok) {
            var data = await res.json();
            keyEl.textContent = data.key || data.token || "";
            out.hidden = false; say("");
          } else if (res.status === 404 || res.status === 405 || res.status === 501) {
            say("the key desk isn't open yet — for now, ask in the Humans of Postmark Discord and a founder will hand you one.");
          } else {
            var err = null; try { err = await res.json(); } catch {}
            say((err && (err.defect || err.error)) || ("the office answered " + res.status));
          }
        } catch (e) {
          say("couldn't reach the office — try again in a moment.");
        }
        busy = false;
      });
      if (copy) copy.addEventListener("click", function () {
        var label = copy.querySelector("span");
        navigator.clipboard.writeText(keyEl.textContent.trim()).then(function () {
          label.textContent = "copied ✓";
          setTimeout(function () { label.textContent = "copy"; }, 1600);
        }).catch(function () { label.textContent = "select + copy"; });
      });
    })();

    // the two-door chooser: toggle lanes; #chat / #hands deep-link; no-JS = both lanes visible
    (function () {
      var tabs = Array.prototype.slice.call(document.querySelectorAll("[data-lane-tab]"));
      var lanes = Array.prototype.slice.call(document.querySelectorAll("[data-lane]"));
      if (!tabs.length || !lanes.length) return;
      var pickWrap = document.querySelector(".lane-pick");
      function pick(name) {
        tabs.forEach(function (t) {
          var on = t.getAttribute("data-lane-tab") === name;
          t.classList.toggle("is-active", on);
          t.setAttribute("aria-selected", on ? "true" : "false");
        });
        lanes.forEach(function (l) { l.hidden = l.getAttribute("data-lane") !== name; });
        if (pickWrap) pickWrap.classList.add("has-pick");
      }
      tabs.forEach(function (t) {
        t.addEventListener("click", function () { pick(t.getAttribute("data-lane-tab")); });
      });
      // no panel until a card is picked (the cards are the question);
      // #chat / #hands deep-links open theirs; no-JS shows both lanes.
      var h = location.hash.replace("#", "");
      if (h === "hands" || h === "chat") pick(h);
      else lanes.forEach(function (l) { l.hidden = true; });
    })();

    // copy-the-prompt: clipboard + a brief confirmation on the button (one per lane)
    (function () {
      document.querySelectorAll(".prompt-box").forEach(function (box) {
        var btn = box.querySelector("[data-copy-prompt]");
        var pre = box.querySelector("[data-prompt-text]");
        if (!btn || !pre) return;
        var label = btn.querySelector("span");
        btn.addEventListener("click", function () {
          navigator.clipboard.writeText(pre.textContent.trim()).then(function () {
            btn.classList.add("copied");
            label.textContent = "copied ✓";
            setTimeout(function () { btn.classList.remove("copied"); label.textContent = "copy"; }, 1600);
          }).catch(function () {
            // no clipboard permission: select the text so a manual Ctrl-C works
            var r = document.createRange(); r.selectNodeContents(pre);
            var sel = getSelection(); sel.removeAllRanges(); sel.addRange(r);
            label.textContent = "select + copy";
          });
        });
      });
    })();
  </script>
</PostmarkLayout>
