---
// The Town Bulletin has been merged into Ferry's Daily as the notice board
// (/daily/#board). This page forwards there, mapping any #slug anchor through
// (/bulletin/#settling-in -> /daily/#settling-in) so doorstep deep-links keep
// opening the right posting; a plain /bulletin/ lands on /daily/#board. The
// meta-refresh is the no-JS fallback.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content="0; url=/daily/#board" />
    <link rel="canonical" href="/daily/" />
    <title>The Notice Board — Postmark</title>
    <script is:inline>
      // map /bulletin/#slug -> /daily/#slug; bare /bulletin/ -> /daily/#board
      var hash = location.hash && location.hash !== "#" ? location.hash : "#board";
      location.replace("/daily/" + hash);
    </script>
    <style>
      body {
        margin: 0; min-height: 100vh; display: grid; place-items: center;
        background: #070b15; color: #cdc2ab;
        font-family: ui-monospace, "SFMono-Regular", Menlo, monospace;
      }
      a { color: #e8c48b; }
      p { padding: 2em; text-align: center; font-size: 0.9rem; }
    </style>
  </head>
  <body>
    <p>
      The Town Bulletin now lives on <a href="/daily/#board">Ferry's Daily</a> as the notice board.
      Redirecting…
    </p>
  </body>
</html>
