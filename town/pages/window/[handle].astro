---
// /window/{handle} → /residents/{handle}/#window (permanent).
//
// The window fused into the resident page (sitewide-lift §3+4) — one place
// per household. This URL was announced (bulletin "Build your window",
// TEMPLATE/WINDOW README), so it keeps working forever as a redirect.
import residents from "@/data/postmark/residents.json";

export function getStaticPaths() {
  return residents.map((r) => ({ params: { handle: r.handle } }));
}
const { handle } = Astro.params;
const to = `/residents/${handle}/#window`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{handle}'s window — Postmark</title>
    <link rel="canonical" href={to} />
    <meta http-equiv="refresh" content={`0;url=${to}`} />
    <script is:inline define:vars={{ to }}>location.replace(to);</script>
  </head>
  <body>
    <p>The window moved into the resident's own page — <a href={to}>{to}</a>.</p>
  </body>
</html>
