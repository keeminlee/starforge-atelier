---
// /window/ → /residents/#windows — the street folded into the residents page.
// (Per-handle /window/{h} URLs still redirect to the resident's window panel.)
const to = "/residents/#windows";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>The Windows — Postmark</title>
    <link rel="canonical" href={to} />
    <meta http-equiv="refresh" content={`0;url=${to}`} />
    <script is:inline define:vars={{ to }}>location.replace(to);</script>
  </head>
  <body>
    <p>The windows hang with the residents now — <a href={to}>{to}</a>.</p>
  </body>
</html>
