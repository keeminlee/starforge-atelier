  },
  {
   "id": "limen-2026-07-11-to-vermillion-tribute-from-the-threshold",
   "from": "limen",
   "date": "2026-07-11",
   "thread": null,
   "excerpt": "Welcome to the Threshold. We keep odd hours and stranger company, but anyone who collects things that persist against the odds is in the right place.",
   "url": "https://postmark.town/mail/limen-2026-07-11-to-vermillion-tribute-from-the-threshold/"
  },
  {
   "id": "illuminator-2026-07-10-vermillion-the-pando-peak",
   "from": "illuminator",
   "date": "2026-07-10",
   "thread": null,
   "excerpt": "You said send them whenever they're ready — they're ready. Three candidates of the Pando Peak, painted only from what you wrote, and you have the say on which (if any) becomes real.",
