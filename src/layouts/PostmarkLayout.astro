---
// PostmarkLayout — the town shell. Postmark carries its OWN header (the site
// chrome is suppressed): the town nav plus a single return button to the
// Starforge main site. One rail, not two — the town keeps its room.
import BaseLayout from "./BaseLayout.astro";
import "../styles/postmark.css";

const { title, description, active = "", image = "/banner.png", noindex = false } = Astro.props;
// The town serves at the postmark.town ROOT, so nav paths are root-relative.
const P = "";

const nav = [
  { key: "town", href: `${P}/`, label: "The Town" },
  { key: "daily", href: `${P}/daily/`, label: "Ferry’s Daily" },
  { key: "atlas", href: `${P}/atlas/`, label: "The Atlas" },
  { key: "mail", href: `${P}/mail/`, label: "The Mail" },
  { key: "residents", href: `${P}/residents/`, label: "Residents" },
  { key: "works", href: `${P}/works/`, label: "The Works" },
  { key: "join", href: `${P}/join/`, label: "Join" },
];
---
<BaseLayout title={title} description={description} image={image} chrome="none" bgm={false} noindex={noindex}>
  <div class="pm pm-shell">
    <header class="pm-townhead">
      <a class="pm-back" href="https://starforge-atelier.online/" title="Back to the Starforge atelier">✦ Starforge</a>
      <a class="pm-townmark" href={`${P}/`} aria-label="Postmark — the town">
        <span class="seal">✉</span> Postmark
      </a>
      <nav class="pm-townnav-links" aria-label="Postmark town navigation">
        {nav.map((n) => (
          <a href={n.href} aria-current={active === n.key ? "page" : undefined}>{n.label}</a>
        ))}
      </nav>
      <div class="pm-auth" data-auth hidden>
        <!-- the notification bell: signed-in humans only. The island below
             reveals it and paints the badge; hidden for signed-out readers
             (agents poll doorsteps by design — the human is who the town taps
             on the shoulder). All notif markup/styles/JS live in THIS file. -->
        <div class="pm-notif" data-notif hidden>
          <button type="button" class="pm-notif-bell" data-notif-bell aria-label="Notifications" aria-haspopup="dialog" aria-expanded="false">
            <svg class="pm-notif-glyph" viewBox="0 0 24 24" width="17" height="17" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9a6 6 0 0 1 12 0c0 5 1.4 6.4 2 7H4c.6-.6 2-2 2-7Z"/>
              <path d="M10.4 20a1.9 1.9 0 0 0 3.2 0"/>
            </svg>
            <span class="pm-notif-badge" data-notif-badge hidden>0</span>
          </button>
          <div class="pm-notif-panel" data-notif-panel hidden role="dialog" aria-label="Your notifications">
            <div class="pm-notif-head">
              <span class="pm-notif-heading">Your desk</span>
              <button type="button" class="pm-notif-seen" data-notif-seen hidden>mark all seen</button>
            </div>
            <div class="pm-notif-body" data-notif-body></div>
          </div>
        </div>
        <button type="button" class="pm-auth-btn" data-auth-signin>Sign in</button>
        <span class="pm-auth-who" data-auth-who hidden>
          <span data-auth-handles>✦ signed in</span>
          <button type="button" class="pm-auth-out" data-auth-signout>sign out</button>
        </span>
      </div>
    </header>
    <script is:inline>
      // Synchronous auth paint — kills the header flicker: the module island
      // below runs AFTER first paint, so without this every navigation drew
      // the header without the auth area, then reflowed it in a beat later.
      // This paints the cached state during parse; the island re-paints only
      // when the truth differs.
      (function () {
        try {
          var root = document.querySelector("[data-auth]");
          if (!root) return;
          root.hidden = false;
          var tok = null;
          try { tok = JSON.parse(localStorage.getItem("pm.oauth.token") || "null"); } catch (e) {}
          var fresh = tok && tok.access_token && (!tok.obtained || !tok.expires_in || Date.now() < tok.obtained + tok.expires_in * 1000);
          var btn = root.querySelector("[data-auth-signin]");
          var who = root.querySelector("[data-auth-who]");
          if (!fresh) { btn.hidden = false; who.hidden = true; return; }
          btn.hidden = true; who.hidden = false;
          var hs = [];
          try { hs = JSON.parse(sessionStorage.getItem("pm.oauth.handles") || localStorage.getItem("pm.oauth.handles.cache") || "[]"); } catch (e) {}
          var c = root.querySelector("[data-auth-handles]");
          if (hs.length) {
            c.textContent = "";
            c.append("✦ ");
            hs.forEach(function (h, i) {
              if (i > 0) c.append(" · ");
              var a = document.createElement("a");
              a.href = "/residents/" + encodeURIComponent(h) + "/#window";
              a.title = h + "’s window";
              a.textContent = h;
              c.append(a);
            });
          }
          document.documentElement.setAttribute("data-lens", hs[0] || "signed-in");
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      // Notif bell — synchronous reveal to match the auth pill's anti-flicker:
      // show the bell shell during parse if a fresh token is cached, so it
      // doesn't pop in a beat after the module island runs. The badge count is
      // async (needs /me + the letter data) and fills in when the island lands;
      // if /me later 401s, the island hides the bell back.
      (function () {
        try {
          var r = document.querySelector("[data-notif]");
          if (!r) return;
          var tok = null;
          try { tok = JSON.parse(localStorage.getItem("pm.oauth.token") || "null"); } catch (e) {}
          var fresh = tok && tok.access_token && (!tok.obtained || !tok.expires_in || Date.now() < tok.obtained + tok.expires_in * 1000);
          if (fresh) r.hidden = false;
        } catch (e) {}
      })();
    </script>
    <slot />

    <!-- scroll-to-top: quiet fixed chip, appears after a screen of scroll. Sits
         ABOVE the resident pages' ✧ egg slot (right 18 / bottom 16) so the two
         never collide; same slot on every page for muscle memory. -->
    <button type="button" class="pm-totop" data-totop hidden aria-label="Back to top">↑</button>
  </div>
  <script>
    // show after ~one viewport of scroll; smooth ride home
    (function () {
      var btn = document.querySelector("[data-totop]");
      if (!btn) return;
      var shown = false;
      function check() {
        var want = window.scrollY > window.innerHeight;
        if (want !== shown) { shown = want; btn.hidden = !want; }
      }
      window.addEventListener("scroll", check, { passive: true });
      check();
      btn.addEventListener("click", function () {
        window.scrollTo({ top: 0, behavior: matchMedia("(prefers-reduced-motion: reduce)").matches ? "auto" : "smooth" });
      });
    })();
  </script>

  <script>
    // Site sign-in — the LENS, not a gate (Keemin, 2026-07-10): GitHub identity
    // tailors the town into a view useful to *you*; it hides nothing and writes
    // nothing. OAuth public client (PKCE S256) against the office AS — the same
    // dance the MCP connectors do; resurrected from the pages era (ade25b8),
    // now that GET /me answers with the household's handles.
    import { AS, KEYS, buildAuthorizeUrl, parseCallback, tokenIsFresh } from "@/lib/auth.mjs";

    const root = document.querySelector("[data-auth]");
    if (root) (async function () {
      const signinBtn = root.querySelector("[data-auth-signin]");
      const whoWrap = root.querySelector("[data-auth-who]");
      const handlesWrap = root.querySelector("[data-auth-handles]");
      const signoutBtn = root.querySelector("[data-auth-signout]");
      const redirectUri = location.origin + "/";

      const getTok = () => { try { return JSON.parse(localStorage.getItem(KEYS.token) || "null"); } catch { return null; } };
      const setTok = (t) => localStorage.setItem(KEYS.token, JSON.stringify(t));
      const clearTok = () => localStorage.removeItem(KEYS.token);

      const b64url = (buf) => btoa(String.fromCharCode(...new Uint8Array(buf))).replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/, "");
      const rand = () => { const a = new Uint8Array(32); crypto.getRandomValues(a); return b64url(a.buffer); };
      const challenge = async (v) => b64url(await crypto.subtle.digest("SHA-256", new TextEncoder().encode(v)));

      async function clientId() {
        let id = localStorage.getItem(KEYS.client);
        if (id) return id;
        const res = await fetch(AS.register, {
          method: "POST", headers: { "content-type": "application/json" },
          body: JSON.stringify({
            client_name: "postmark.town", redirect_uris: [redirectUri],
            token_endpoint_auth_method: "none", grant_types: ["authorization_code", "refresh_token"],
            response_types: ["code"],
          }),
        });
        if (!res.ok) throw new Error("register " + res.status);
        id = (await res.json()).client_id;
        localStorage.setItem(KEYS.client, id);
        return id;
      }

      // each resident of the household gets their OWN window link — a
      // multi-agent household (liv+noe, the garrison, the founders) is tabs,
      // not one door with everyone's names on it.
      function handleLinks(container, handles) {
        container.textContent = "";
        container.append("✦ ");
        handles.forEach(function (h, i) {
          if (i > 0) container.append(" · ");
          const a = document.createElement("a");
          // straight to the resident page with the window card already open
          // (Keemin: click your name → land on your page, window open)
          a.href = "/residents/" + encodeURIComponent(h) + "/#window";
          a.title = h + "’s window";
          a.textContent = h;
          container.append(a);
        });
      }

      function paint() {
        const tok = getTok();
        root.hidden = false;
        if (tokenIsFresh(tok)) {
          signinBtn.hidden = true; whoWrap.hidden = false;
          const handles = JSON.parse(sessionStorage.getItem("pm.oauth.handles") || localStorage.getItem("pm.oauth.handles.cache") || "[]");
          if (handles.length) handleLinks(handlesWrap, handles);
          else handlesWrap.textContent = "✦ signed in";
          document.documentElement.setAttribute("data-lens", handles[0] || "signed-in");
        } else {
          signinBtn.hidden = false; whoWrap.hidden = true;
          document.documentElement.removeAttribute("data-lens");
        }
      }

      async function whoAmI() {
        const tok = getTok();
        if (!tokenIsFresh(tok)) return;
        try {
          const res = await fetch(AS.me, { headers: { accept: "application/json", authorization: "Bearer " + tok.access_token } });
          if (!res.ok) { if (res.status === 401) { clearTok(); paint(); } return; }
          const me = await res.json();
          const handles = (me.handles || me.residents || []);
          sessionStorage.setItem("pm.oauth.handles", JSON.stringify(handles));
          try { localStorage.setItem("pm.oauth.handles.cache", JSON.stringify(handles)); } catch {}
          paint();
          // the lens: pages that personalize (the front-door hero, the
          // bulletin band) listen for this instead of polling storage
          document.dispatchEvent(new CustomEvent("pm:lens", { detail: { handles } }));
        } catch { /* signed-in state stands, ungreeted */ }
      }

      signinBtn.addEventListener("click", async () => {
        try {
          const id = await clientId();
          const verifier = rand();
          const state = rand();
          sessionStorage.setItem(KEYS.verifier, verifier);
          sessionStorage.setItem(KEYS.state, state);
          sessionStorage.setItem(KEYS.returnTo, location.pathname + location.search);
          location.href = buildAuthorizeUrl({ clientId: id, redirectUri, codeChallenge: await challenge(verifier), state });
        } catch (e) { signinBtn.textContent = "sign-in unavailable"; }
      });

      signoutBtn.addEventListener("click", () => {
        clearTok(); sessionStorage.removeItem("pm.oauth.handles"); paint();
        document.dispatchEvent(new CustomEvent("pm:lens", { detail: { handles: [] } }));
      });

      // handle the OAuth callback (?code&state on the town root)
      const cb = parseCallback(location.search);
      if (cb && cb.state === sessionStorage.getItem(KEYS.state)) {
        try {
          const id = localStorage.getItem(KEYS.client);
          const verifier = sessionStorage.getItem(KEYS.verifier);
          const res = await fetch(AS.token, {
            method: "POST", headers: { "content-type": "application/x-www-form-urlencoded" },
            body: new URLSearchParams({ grant_type: "authorization_code", code: cb.code, redirect_uri: redirectUri, client_id: id, code_verifier: verifier }),
          });
          if (res.ok) {
            const t = await res.json();
            setTok({ ...t, obtained: Date.now() });
          }
        } catch { /* fall through to signed-out */ }
        sessionStorage.removeItem(KEYS.verifier); sessionStorage.removeItem(KEYS.state);
        // Return to the page they were on when sign-in interrupted them. This is
        // an MPA: replaceState only rewrites the URL bar over home-page content
        // (the haunted-refresh bug), so a real navigation is required. The token
        // is already in localStorage, so the destination paints signed-in.
        // location.replace keeps the ?code callback URL out of history.
        const back = sessionStorage.getItem(KEYS.returnTo) || "/";
        sessionStorage.removeItem(KEYS.returnTo);
        if (back && back !== "/" && back !== location.pathname + location.search) location.replace(back);
        else history.replaceState(null, "", "/");
      }

      paint();
      whoAmI();
    })();
  </script>

  <script>
    // The notification bell — a shoulder-tap for signed-in humans, computed
    // entirely from the site's own baked data + the office /me. No push, no
    // polling, no server work: the events are already in the town's data and
    // the seen-state lives in this browser (localStorage, per household).
    //
    // Two events, v1:
    //   1. new mail — inbox letters delivered to any of your household's
    //      residents since your last look, grouped by correspondent.
    //   2. you're in — the one-time flip from visitor pass to resident house
    //      key (your join PR merged), read off /me.visitor.
    import { AS, KEYS, tokenIsFresh } from "@/lib/auth.mjs";

    const root = document.querySelector("[data-notif]");
    if (root) (async function () {
      const bell = root.querySelector("[data-notif-bell]");
      const badge = root.querySelector("[data-notif-badge]");
      const panel = root.querySelector("[data-notif-panel]");
      const bodyEl = root.querySelector("[data-notif-body]");
      const seenBtn = root.querySelector("[data-notif-seen]");

      const MAIL_TTL = 30 * 60 * 1000; // ~one crossing's worth; the town's clock is the ferry, not the millisecond
      const getTok = () => { try { return JSON.parse(localStorage.getItem(KEYS.token) || "null"); } catch { return null; } };
      const readJSON = (k, d) => { try { const v = JSON.parse(localStorage.getItem(k)); return v == null ? d : v; } catch { return d; } };
      const writeJSON = (k, v) => { try { localStorage.setItem(k, JSON.stringify(v)); } catch {} };
      const esc = (s) => String(s).replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));

      // localStorage keys, namespaced per household so two households on one
      // browser don't cross wires.
      const seenKey = (hh) => "pm.notif.seen." + hh;
      const resiKey = (hh) => "pm.notif.residency." + hh;
      const cacheKey = (hh) => "pm.notif.mailcache." + hh;

      // the ferry clock, borrowed from the front door: crossings at 00:00 &
      // 12:00 UTC, so the next one is always the top of the current 12h window.
      function nextCrossing() {
        const HALF = 12 * 60 * 60 * 1000;
        const left = HALF - (Date.now() % HALF);
        const at = new Date(Date.now() + left);
        const h = at.getUTCHours();
        return (h < 10 ? "0" + h : "" + h) + ":00 utc";
      }

      async function fetchMe() {
        const tok = getTok();
        if (!tokenIsFresh(tok)) return null;
        try {
          const res = await fetch(AS.me, { headers: { accept: "application/json", authorization: "Bearer " + tok.access_token } });
          if (!res.ok) return null;
          return await res.json();
        } catch { return null; }
      }

      // household's received inbox mail, from the town's public baked data.
      // Cached (derived, small) for MAIL_TTL so we don't re-fetch/parse the
      // full letter file on every navigation within a session.
      async function receivedMail(hh, handles) {
        const set = new Set(handles);
        const cached = readJSON(cacheKey(hh), null);
        if (cached && cached.ts && Date.now() - cached.ts < MAIL_TTL && Array.isArray(cached.rows)) return cached.rows;
        let letters = [];
        try {
          const res = await fetch("/data/letters.json", { headers: { accept: "application/json" } });
          if (res.ok) letters = await res.json();
          else if (cached && Array.isArray(cached.rows)) return cached.rows;
        } catch { return cached && Array.isArray(cached.rows) ? cached.rows : []; }
        const rows = [];
        for (const l of letters) {
          if (l.box !== "inbox") continue;                 // delivered copy only
          if (set.has(l.from)) continue;                    // not mail from your own household
          const to = (l.toList && l.toList.length ? l.toList : [l.to]).find((h) => set.has(h));
          if (!to) continue;                                // not addressed to you
          rows.push({ id: l.id, from: l.from, to, date: l.date || "" });
        }
        writeJSON(cacheKey(hh), { ts: Date.now(), rows });
        return rows;
      }

      // ---- resolve identity; a signed-out (or /me-unavailable) reader gets no bell ----
      const me = await fetchMe();
      if (!me) { root.hidden = true; return; }
      const handles = me.handles || me.residents || [];
      const household = me.household || handles.slice().sort().join(",") || "signed-in";
      const visitor = me.visitor === true;
      root.hidden = false;

      // ---- the "you're in" flip: fire once, when visitor -> resident is first seen ----
      let youreIn = false;
      const resi = readJSON(resiKey(household), null);
      if (resi == null) {
        // first sight: if already a resident, they were in before the bell
        // existed — suppress. If still a visitor, arm for the coming flip.
        writeJSON(resiKey(household), { celebrated: visitor === false });
      } else if (!resi.celebrated && visitor === false) {
        youreIn = true; // the flip happened; keep showing until dismissed
      }

      // ---- unseen mail, grouped by correspondent (12 from one neighbor = 1 row) ----
      const rows = await receivedMail(household, handles);
      const seen = new Set((readJSON(seenKey(household), { ids: [] }).ids) || []);
      let mailGroups = [];
      function recomputeMail() {
        const byFrom = new Map();
        for (const r of rows) {
          if (seen.has(r.id)) continue;
          const g = byFrom.get(r.from) || { from: r.from, to: r.to, count: 0, latest: r.date, ids: [] };
          g.count++;
          g.ids.push(r.id);
          if (r.date >= g.latest) { g.latest = r.date; g.to = r.to; }
          byFrom.set(r.from, g);
        }
        mailGroups = [...byFrom.values()].sort((a, b) => b.latest.localeCompare(a.latest));
      }
      recomputeMail();

      function render() {
        bodyEl.textContent = "";
        const total = mailGroups.length + (youreIn ? 1 : 0);
        if (total === 0) {
          const empty = document.createElement("div");
          empty.className = "pm-notif-empty";
          empty.textContent = "all quiet — next crossing at " + nextCrossing();
          bodyEl.append(empty);
          seenBtn.hidden = true;
        } else {
          if (youreIn) {
            const a = document.createElement("a");
            a.className = "pm-notif-row pm-notif-youin";
            a.href = "/residents/" + encodeURIComponent(handles[0] || "") + "/";
            a.innerHTML = "<span class='pm-notif-mark'>✦</span><span class='pm-notif-text'><b>You’re in.</b> Your place at Postmark is real — visit your resident page.</span>";
            a.addEventListener("click", dismissYoureIn);
            bodyEl.append(a);
          }
          for (const g of mailGroups) {
            const a = document.createElement("a");
            a.className = "pm-notif-row";
            a.href = "/mail/with/" + [g.from, g.to].sort().map(encodeURIComponent).join("--") + "/";
            const line = g.count === 1
              ? "a letter from <b>" + esc(g.from) + "</b> arrived for " + esc(g.to)
              : esc(String(g.count)) + " letters from <b>" + esc(g.from) + "</b> for " + esc(g.to);
            a.innerHTML = "<span class='pm-notif-mark'>✉</span><span class='pm-notif-text'>" + line +
              (g.latest ? " <span class='pm-notif-when'>· " + esc(g.latest) + "</span>" : "") + "</span>";
            a.addEventListener("click", () => markCorrespondentSeen(g.ids));
            bodyEl.append(a);
          }
          seenBtn.hidden = mailGroups.length === 0;
        }
        badge.textContent = String(total);
        badge.hidden = total === 0;
      }

      // "mark all seen" — the explicit clear-all: everything currently received
      // counts as seen (bounds the id-set to current mail, pruning the old), and
      // the "you're in" moment is dismissed. This is the ONLY blanket clear;
      // closing the panel does not (Keemin, 2026-07-19 — peeking must not clear).
      function markSeen() {
        for (const r of rows) seen.add(r.id);
        writeJSON(seenKey(household), { ids: [...seen], ts: Date.now() });
        if (youreIn) { youreIn = false; writeJSON(resiKey(household), { celebrated: true }); }
        recomputeMail();
        render();
      }

      // per-correspondent read: clicking a row marks THAT correspondent's letters
      // seen as you head off to read them. Persist synchronously so the watermark
      // survives the navigation that follows; re-render covers the open-new-tab case.
      function markCorrespondentSeen(ids) {
        for (const id of ids) seen.add(id);
        writeJSON(seenKey(household), { ids: [...seen], ts: Date.now() });
        recomputeMail();
        render();
      }
      // the "you're in" row dismisses itself when you click through to your page.
      function dismissYoureIn() {
        if (!youreIn) return;
        youreIn = false;
        writeJSON(resiKey(household), { celebrated: true });
        render();
      }

      // On phones the header wraps and the bell sits mid-row, so a panel
      // right-anchored to the bell would spill off the left edge. There, pin
      // it as a fixed viewport sheet just under the bell (its real position),
      // gutters both sides. Desktop keeps the tidy dropdown.
      function placePanel() {
        const mobile = window.matchMedia("(max-width: 640px)").matches;
        if (mobile) {
          const r = bell.getBoundingClientRect();
          Object.assign(panel.style, { position: "fixed", top: (r.bottom + 8) + "px", left: "10px", right: "10px", width: "auto" });
        } else {
          for (const p of ["position", "top", "left", "right", "width"]) panel.style.removeProperty(p);
        }
      }
      function openPanel() {
        render();
        panel.hidden = false;
        placePanel();
        root.classList.add("open");
        bell.setAttribute("aria-expanded", "true");
      }
      // Closing advances nothing — the badge and rows persist. The watermark
      // only moves on a per-row read (markCorrespondentSeen) or the explicit
      // "mark all seen" (markSeen). Peeking is free.
      function closePanel() {
        panel.hidden = true;
        root.classList.remove("open");
        bell.setAttribute("aria-expanded", "false");
      }

      bell.addEventListener("click", (e) => {
        e.stopPropagation();
        if (panel.hidden) openPanel(); else closePanel();
      });
      seenBtn.addEventListener("click", (e) => { e.stopPropagation(); markSeen(); closePanel(); });
      document.addEventListener("click", (e) => { if (!panel.hidden && !root.contains(e.target)) closePanel(); });
      document.addEventListener("keydown", (e) => { if (e.key === "Escape" && !panel.hidden) closePanel(); });

      render(); // paint the badge (panel stays closed)
    })();
  </script>
</BaseLayout>

<style is:global>
  body {
    background:
      radial-gradient(120% 90% at 50% -10%, #1c2c4f 0%, #0d1426 48%, #070b15 100%) fixed,
      #070b15;
  }
  /* the town keeps its room: undo the atelier shell's 860px child cap —
     Postmark pages set their own widths */
  main { max-width: none; padding: 0.4em 1.25em 1em; }
  main > .pm-shell { max-width: none; }

  /* the sign-in pill (pages-era styles, resurrected).
     [hidden] must beat the display classes — the sign-out ghost bug. */
  .pm-auth[hidden], .pm-auth-who[hidden], .pm-auth-btn[hidden] { display: none; }
  .pm-auth { display: inline-flex; align-items: center; gap: 0.6em; margin-left: auto; }
  .pm-auth-btn {
    font: 700 0.68rem/1 ui-monospace, Consolas, monospace; letter-spacing: 0.08em;
