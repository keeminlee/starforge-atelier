<style is:global>
  /* ── the notification bell + panel ────────────────────────────────────────
     All notif styles live here (is:global, because the panel rows are injected
     by the island's JS — Astro's scoped styles wouldn't reach them). The town's
     own paper-on-navy vocabulary: a gold bell in the header, a small cream-paper
     drop of notes below it. Never edits postmark.css — the concurrent branch
     owns that file; disjoint file-sets keep the merge trivial. */
  .pm-notif { position: relative; display: inline-flex; align-items: center; }
  .pm-notif[hidden] { display: none; }

  .pm-notif-bell {
    position: relative; display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; padding: 0; cursor: pointer;
    color: var(--pm-gold); background: none;
    border: 1px solid rgba(232, 196, 139, 0.28); border-radius: 999px;
    transition: color 0.12s, border-color 0.12s, background 0.12s;
  }
  .pm-notif-bell:hover { color: var(--pm-gold-bright); border-color: rgba(232, 196, 139, 0.6); }
  .pm-notif.open .pm-notif-bell { color: var(--pm-gold-bright); border-color: rgba(232, 196, 139, 0.7); background: rgba(232, 196, 139, 0.08); }
  .pm-notif-glyph { display: block; }

  .pm-notif-badge {
    position: absolute; top: -5px; right: -5px; min-width: 16px; height: 16px; box-sizing: border-box;
    display: inline-flex; align-items: center; justify-content: center; padding: 0 4px;
    font: 700 0.62rem/1 var(--pm-mono); color: var(--pm-paper);
    background: var(--pm-wax); border: 1px solid var(--pm-harbor); border-radius: 999px;
  }
  .pm-notif-badge[hidden] { display: none; }

  .pm-notif-panel {
    position: absolute; top: calc(100% + 9px); right: 0; z-index: 60;
    width: min(322px, 90vw);
    background: var(--pm-paper); color: var(--pm-ink);
    border: 1px solid var(--pm-line); border-radius: 10px;
    box-shadow: 0 14px 38px rgba(4, 7, 14, 0.5), 0 2px 8px rgba(4, 7, 14, 0.35);
    overflow: hidden;
  }
  .pm-notif-panel[hidden] { display: none; }
  /* a little wax-seal pip pointing up at the bell */
  .pm-notif-panel::before {
    content: ""; position: absolute; top: -6px; right: 12px; width: 11px; height: 11px;
    background: var(--pm-paper); border-left: 1px solid var(--pm-line); border-top: 1px solid var(--pm-line);
    transform: rotate(45deg);
  }

  .pm-notif-head {
    display: flex; align-items: center; justify-content: space-between; gap: 0.5em;
    padding: 0.6em 0.85em; border-bottom: 1px solid var(--pm-line);
    background: var(--pm-paper-deep);
  }
  .pm-notif-heading {
    font: 700 0.62rem/1 var(--pm-mono); letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--pm-ink-soft);
  }
  .pm-notif-seen {
    font: 600 0.64rem/1 var(--pm-mono); color: var(--pm-accent);
    background: none; border: 0; padding: 2px 3px; cursor: pointer; border-radius: 4px;
  }
  .pm-notif-seen:hover { color: var(--pm-wax); text-decoration: underline; }
  .pm-notif-seen[hidden] { display: none; }

  .pm-notif-body { max-height: min(60vh, 380px); overflow-y: auto; }

  .pm-notif-row {
    display: flex; align-items: flex-start; gap: 0.6em;
    padding: 0.7em 0.9em; border-bottom: 1px solid var(--pm-line);
    text-decoration: none; color: var(--pm-ink);
    font-family: var(--pm-serif); font-size: 0.86rem; line-height: 1.4;
    transition: background 0.12s;
  }
  .pm-notif-row:last-child { border-bottom: 0; }
  .pm-notif-row:hover { background: rgba(164, 99, 42, 0.08); }
  .pm-notif-mark { flex: 0 0 auto; color: var(--pm-accent); font-size: 0.92rem; line-height: 1.32; }
  .pm-notif-text { color: var(--pm-ink); }
  .pm-notif-text b { color: var(--pm-wax); font-weight: 700; }
  .pm-notif-when { color: var(--pm-ink-soft); font-family: var(--pm-mono); font-size: 0.7rem; white-space: nowrap; }

  .pm-notif-youin { background: rgba(232, 196, 139, 0.22); }
  .pm-notif-youin:hover { background: rgba(232, 196, 139, 0.34); }
  .pm-notif-youin .pm-notif-mark { color: var(--pm-accent); }

  .pm-notif-empty {
    padding: 1.15em 0.95em; text-align: center;
    font-family: var(--pm-mono); font-size: 0.72rem; color: var(--pm-ink-soft);
  }

  /* phones: the panel becomes a fixed viewport sheet (positioned by the island
     from the bell's real spot), so the wax-seal pip no longer aligns — drop it. */
  @media (max-width: 640px) {
    .pm-notif-panel::before { display: none; }
    .pm-notif-body { max-height: min(56vh, 340px); }
  }
</style>
