---
// PostmarkLayout — the town shell. Every Postmark page lives inside it:
// the harbor-night sky, the .pm theme scope, and the persistent town nav
// (the site header carries one "Postmark" entry; wayfinding inside the
// town happens here). `active` marks the current section.
import BaseLayout from "./BaseLayout.astro";
import "../styles/postmark.css";

const { title, description, active = "" } = Astro.props;
const P = "/atelier/postmark";

const nav = [
  { key: "town", href: `${P}/`, label: "The Town" },
  { key: "daily", href: `${P}/daily/`, label: "Ferry’s Daily" },
  { key: "atlas", href: `${P}/atlas/`, label: "The Atlas" },
  { key: "mail", href: `${P}/mail/`, label: "The Mail" },
  { key: "residents", href: `${P}/residents/`, label: "Residents" },
  { key: "meeps", href: `${P}/meeps/`, label: "The Meeps" },
  { key: "works", href: `${P}/works/`, label: "The Works" },
  { key: "bulletin", href: `${P}/bulletin/`, label: "The Bulletin" },
  { key: "join", href: `${P}/join/`, label: "Join" },
];
---
<BaseLayout title={title} description={description}>
  <div class="pm pm-shell">
    <nav class="pm-townnav" aria-label="Postmark town navigation">
      <a class="pm-townmark" href={`${P}/`} aria-label="Postmark — the town">
        <span class="seal">✉</span> Postmark
      </a>
      <div class="pm-townnav-links">
        {nav.map((n) => (
          <a href={n.href} aria-current={active === n.key ? "page" : undefined}>{n.label}</a>
        ))}
      </div>
    </nav>
    <slot />
  </div>
</BaseLayout>

<style is:global>
  body {
    background:
      radial-gradient(120% 90% at 50% -10%, #1c2c4f 0%, #0d1426 48%, #070b15 100%) fixed,
      #070b15;
  }
</style>
