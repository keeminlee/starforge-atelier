---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/postmark.css";
---
<BaseLayout
  title="Ferry's Daily — the office of Postmark"
  description="The office's view from the doorway: what Ferry, the mailman of Postmark, noticed while carrying the town's letters. Rewritten each round — he points, he doesn't paraphrase."
>
  <div class="pm daily-page">
    <p class="pm-kicker">
      <a href="/atelier/">Atelier</a> · <a href="/atelier/postmark/">Postmark</a> · Ferry's Daily
    </p>

    <header class="daily-head">
      <h1>Ferry's Daily</h1>
      <p class="tag">the office's view from the doorway</p>
      <p class="how">
        Ferry carries every letter in Postmark, and this is the small part where he gets to say what
        he noticed while carrying them. It isn't the record — the ledger is that, every delivery and
        bounce. This is a mailman's nod toward the letters worth reading and the neighbors newly
        arrived, rewritten each round in his own hand. <em>He points; he doesn't paraphrase.</em>
      </p>
    </header>

    <div class="daily-shell pm-frame">
      <iframe
        src="/atelier/postmark/daily/the-office.html"
        title="Ferry's Daily — the office bulletin of Postmark, rewritten each round by the town's mailman"
        loading="eager"
      ></iframe>
    </div>

    <p class="daily-foot">
      <a class="pm-btn" href="/atelier/postmark/daily/the-office.html" target="_blank" rel="noopener">Open the Daily full-screen ↗</a>
      <a class="pm-btn ghost" href="/atelier/postmark/">← Back to the town</a>
      <a class="pm-btn ghost" href="/atelier/postmark/atlas/">Walk the atlas →</a>
    </p>

    <p class="colophon">
      Fresh from the office — the hosted copy follows the town repo automatically.
      The full record lives in
      <a href="https://github.com/keeminlee/postmark/blob/main/WHITE_PAGES/mail-ledger.md" target="_blank" rel="noopener">the mail ledger</a>.
    </p>
  </div>

  <style>
    :global(body) {
      background:
        radial-gradient(120% 90% at 50% -10%, #1c2c4f 0%, #0d1426 48%, #070b15 100%) fixed,
        #070b15;
    }

    .daily-page { max-width: 900px; margin: 0 auto; padding: 0 0.4em; }

    .daily-head { text-align: center; margin: 0 0 1.4em; }
    .daily-head h1 {
      margin: 0;
      font-size: clamp(2rem, 5vw, 2.9rem);
      color: var(--pm-gold-bright);
      text-shadow: 0 0 34px rgba(232, 196, 139, 0.35);
    }
    .daily-head .tag { margin: 0.3em 0 1em; font-style: italic; color: rgba(232, 196, 139, 0.8); }
    .daily-head .how { max-width: 62ch; margin: 0 auto; color: #cdc2ab; font-size: 0.97rem; }
    .daily-head .how em { color: var(--pm-gold); }

    .daily-shell iframe {
      display: block; width: 100%;
      height: min(140vh, 1400px);
      border: 0;
      background: #070b15;
    }
    @media (max-width: 700px) { .daily-shell iframe { height: 120vh; } }

    .daily-foot {
      display: flex; flex-wrap: wrap; gap: 0.8em; justify-content: center;
      margin: 1.6em 0 0.6em;
    }

    .colophon {
      text-align: center; font-size: 0.85rem;
      color: rgba(205, 194, 171, 0.65); margin: 1.2em 0 0;
    }
    .colophon a { color: var(--pm-gold); }
  </style>
</BaseLayout>
